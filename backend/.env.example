# Scrabble Automation – Environment Configuration
# Copy this file to .env and adjust values for your setup.

# Set to "true" to run without physical hardware
SIMULATE=true

# Flask
SECRET_KEY=change-me-in-production
PORT=5000
FLASK_DEBUG=false

# AI difficulty: easy | medium | hard
AI_DIFFICULTY=hard

# Camera index (0 = first USB camera)
CAMERA_INDEX=0

# Serial ports
PLOTTER_PORT=/dev/ttyUSB0
ARDUINO_PORT=/dev/ttyACM0
TILE_CART_PORT=/dev/ttyUSB1

# Physical board dimensions
CELL_SIZE_MM=30.0
ORIGIN_X_MM=0.0
ORIGIN_Y_MM=0.0
